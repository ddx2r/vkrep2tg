# Скопируйте в .env и заполните реальными значениями.
# Copy to .env and fill in real values.
# server.js завершится с process.exit(1) (см. src/config.js), если обязательная
# переменная отсутствует.

# --- Обязательные / Required ---

# ID сообщества VK (без минуса), например 123456789
VK_GROUP_ID=

# Секретный ключ Callback API (Настройки сообщества -> Работа с API -> Callback API)
VK_SECRET_KEY=

# Сервисный ключ доступа сообщества (для users.get / likes.getList)
VK_SERVICE_KEY=

# Токен бота из @BotFather
TELEGRAM_BOT_TOKEN=

# ID чата/канала Telegram, куда пересылаются уведомления
TELEGRAM_CHAT_ID=

# URL проекта Supabase (используется для логирования в bot_logs и персистентности
# состояния в bot_state — см. migrations/001_bot_state.sql)
SUPABASE_URL=

# Service Role key проекта Supabase (НЕ anon key — обходит RLS, держите в секрете)
SUPABASE_SERVICE_ROLE_KEY=

# --- Опциональные / Optional ---

# Отдельный чат для дублирования "лидовых" событий (например, выход из группы)
LEAD_CHAT_ID=

# Чат для отладочных сообщений и ошибок
DEBUG_CHAT_ID=

# ID пользователей Telegram с доступом к админ-командам, через запятую
ADMIN_USER_IDS=

# Версия бота, отображаемая в /version (по умолчанию берётся из package.json)
BOT_VERSION=

# Порт HTTP-сервера (по умолчанию 3000)
PORT=3000
